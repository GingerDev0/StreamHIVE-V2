# TMDB credentials
# Prefer the v4 API Read Access Token. The v3 key can be left blank if you use the bearer token.
TMDB_BEARER_TOKEN=your_tmdb_v4_read_access_token_here
TMDB_API_KEY=your_tmdb_v3_api_key_here

# App settings
APP_ENV=local
APP_DEBUG=true
ADMIN_TOKEN=change-this-token

# Leave blank to use storage/database.sqlite
SQLITE_PATH=

# SQLite tuning
# MEMORY avoids slow database.sqlite-wal and database.sqlite-journal sidecar writes.
# For safer but slower writes, use SQLITE_JOURNAL_MODE=DELETE and SQLITE_SYNCHRONOUS=FULL.
SQLITE_JOURNAL_MODE=MEMORY
SQLITE_SYNCHRONOUS=NORMAL
SQLITE_BUSY_TIMEOUT_MS=10000
