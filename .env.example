# TMDB credentials
# Prefer the v4 API Read Access Token. The v3 key can be left blank if you use the bearer token.
TMDB_BEARER_TOKEN=your_tmdb_v4_read_access_token_here
TMDB_API_KEY=your_tmdb_v3_api_key_here

# App settings
APP_ENV=local
APP_DEBUG=true
ADMIN_TOKEN=change-this-token

# MySQL database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=stream_hive
DB_USERNAME=stream_hive
DB_PASSWORD=change-this-password
